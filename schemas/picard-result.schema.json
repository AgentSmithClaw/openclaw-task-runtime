{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "picard-result.schema.json",
  "allOf": [
    {
      "$ref": "./agent_result.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "agent": {
          "const": "picard"
        },
        "decision": {
          "enum": [
            "progress",
            "wait_input",
            "blocked",
            "done",
            "failed"
          ]
        },
        "arbitration": {
          "type": "object",
          "required": [
            "action",
            "reason"
          ],
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "continue",
                "approve_spec",
                "fanout_delivery",
                "reassign",
                "replan",
                "escalate_user",
                "rollback",
                "close"
              ]
            },
            "reason": {
              "type": "string"
            },
            "affectedChildren": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "agent",
        "decision",
        "arbitration"
      ]
    }
  ]
}
