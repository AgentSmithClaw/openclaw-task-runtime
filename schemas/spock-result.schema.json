{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spock-result.schema.json",
  "allOf": [
    {
      "$ref": "./agent_result.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "agent": {
          "const": "spock"
        },
        "decision": {
          "enum": [
            "progress",
            "blocked",
            "done",
            "failed"
          ]
        },
        "specOutputs": {
          "type": "object",
          "required": [
            "featureIds",
            "acceptanceReady",
            "handoffCount"
          ],
          "properties": {
            "featureIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "acceptanceReady": {
              "type": "boolean"
            },
            "handoffCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      },
      "required": [
        "agent",
        "decision",
        "specOutputs"
      ]
    }
  ]
}
